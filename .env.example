# Redis (Phases 0–5) — optional; API works without it (in-memory fallback)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_KEY_PREFIX=nq

# Local Redis: docker compose -f docker-compose.redis.yml up -d

# Single-server concurrency (PM2 cluster — see ecosystem.config.js)
# PM2_INSTANCES=max          # or a number e.g. 2
# RUN_BACKGROUND_JOBS=true     # only instance 0 runs cron + BullMQ worker (default)

# REQUIRED when PM2 runs more than one Node process:
# REDIS_ENABLED=true
